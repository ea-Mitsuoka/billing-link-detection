# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# uv（仮想環境とロックファイル候補）
.venv/
.python-version

# --------------------------------------------------
# Terraform
# --------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log

# tfvars は機密情報を含むため除外（テンプレートはコミット対象）
terraform.tfvars
*.auto.tfvars
!*.tfvars.example

# 注: .terraform.lock.hcl は再現性のため**コミットする**（除外しない）

# --------------------------------------------------
# 環境変数ファイル
# --------------------------------------------------
.env
.env.local
.env.*.local

# --------------------------------------------------
# ビルド成果物（Cloud Functions のアーカイブ等）
# --------------------------------------------------
.tmp/
*.zip

# --------------------------------------------------
# IDE / OS
# --------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
