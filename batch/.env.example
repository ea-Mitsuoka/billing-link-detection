# batch/ ローカル実行用の環境変数テンプレート
# 使い方: cp .env.example .env && source .env
# .env は .gitignore に含めること

# GCP プロジェクト（このシステムをデプロイするプロジェクト）
GCP_PROJECT_ID=your-project-id

# 親請求先アカウントID（dragon.jp）
PARENT_BILLING_ACCOUNT=XXXXXX-YYYYYY-ZZZZZZ

# BQ データセット名（ローカル実行時は本番誤更新を防ぐため必ずテスト用を指定）
BQ_DATASET=billing_data_test

# Billing Export 専用プロジェクト（dragon.jp 用に作成した別プロジェクト）
# 未設定時は GCP_PROJECT_ID と同じ扱い（同一プロジェクト内 export の場合）
BILLING_EXPORT_PROJECT_ID=your-billing-export-project-id

# Billing Export データセット名
BILLING_EXPORT_DATASET=billing_data

# Billing Export テーブル名（フルパスではなくテーブル名のみ）
BILLING_EXPORT_TABLE=gcp_billing_export_v1_XXXXXX

# バッチ種別: "daily"（日次）または "monthly"（月次コスト更新）
BATCH_TYPE=daily
